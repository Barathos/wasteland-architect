      "default": 0
    },
    "resistance_radiation": {
      "type": "number",
      "title": "Radiation Resistance",
      "default": 0
    },
    "resistance_poison": {
      "type": "number",
      "title": "Poison Resistance",
      "default": 0
    },
    "fatigue": {
      "type": "number",
      "title": "Fatigue",
      "default": 0,
      "minimum": 0,
      "maximum": 5
