    },
    "is_well_rested": {
      "type": "boolean",
      "title": "Well Rested",
      "default": false
    },
    "addictions": {
      "type": "string",
      "title": "Addictions JSON"
    },
    "diseases": {
      "type": "string",
      "title": "Diseases JSON"
    },
    "power_armor_health": {
      "type": "string",
      "title": "Power Armor Health JSON"
    },
    "conditions": {
      "type": "string",
      "title": "Conditions JSON"
    },
    "conditions_effects": {
      "type": "string",
      "title": "Conditions & Effects JSON"
    },
    "encumbrance": {
      "type": "number",
      "title": "Current Encumbrance",
      "default": 0
    },
    "injuries": {
      "type": "string",
      "title": "Injuries JSON"
    }
  },
  "required": [
    "name",
    "origin"
  ]
}